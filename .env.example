# Core Application Configuration
APP_NAME="Notes API"
API_V1_PREFIX="/api/v1"

# Database Configuration
# For local SQLite development (async engine):
DATABASE_URL="sqlite+aiosqlite:///./notes.db"

# JWT Security Configurations
# Generate a secure secret key using: openssl rand -hex 32
JWT_SECRET_KEY="generate-a-secure-secret-key-for-production"
JWT_ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=30

# File Upload Configurations
UPLOAD_DIR="uploads"
MAX_UPLOAD_SIZE_MB=5
ALLOWED_FILE_TYPES="jpg,jpeg,png,pdf,txt"
